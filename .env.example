# ─── DAJO env-variabler ─────────────────────────────────────────────────────
# Kopiera till .env.local för lokal utveckling. I produktion: sätt på Render
# (Dashboard → din service → Environment).

# ─── Databas ────────────────────────────────────────────────────────────────
# Lämna tom lokalt för att köra mock-läge
DATABASE_URL=

# ─── Auth ───────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string

# ─── AI-import (valfri) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Pilot admin-allowlist ──────────────────────────────────────────────────
# Kommaseparerad lista över admin-e-post. Styr vem som kan se /admin/pilot.
PILOT_ADMIN_EMAILS=hello@dajo.club

# ─── E-post: välj EN backend ────────────────────────────────────────────────
# App-URL används i mejlknappar. Lämna tom = https://dajo.club
APP_URL=https://dajo.club
EMAIL_FROM="DAJO <hello@dajo.club>"
EMAIL_REPLY_TO=hello@dajo.club

# Alt 1 (rekommenderat i början) — Simply SMTP
SMTP_HOST=smtp.simply.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=hello@dajo.club
SMTP_PASS=ditt-mail-lösenord

# Alt 2 — Resend (byt till denna om du senare vill ha bättre deliverability/dashboard)
# Lämna SMTP_* tomma om du använder Resend — SMTP vinner annars.
RESEND_API_KEY=
